{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://heartsteel-production.up.railway.app/api/$1" },
    { "source": "/socket.io/(.*)", "destination": "https://heartsteel-production.up.railway.app/socket.io/$1" },
    { "source": "/uploads/(.*)", "destination": "https://heartsteel-production.up.railway.app/uploads/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
